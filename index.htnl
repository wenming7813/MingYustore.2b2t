<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>我的世界服务器商店</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Microsoft Yahei", sans-serif;
        }

        body {
            background: #121212;
            color: #fff;
            padding: 20px;
        }

        .header {
            text-align: center;
            padding: 30px 0;
            border-bottom: 1px solid #333;
            margin-bottom: 30px;
        }

        .header h1 {
            color: #4cd964;
            font-size: 28px;
            margin-bottom: 10px;
        }

        .header p {
            color: #aaa;
            font-size: 16px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .shop-card {
            background: #1e1e1e;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #333;
            transition: 0.3s ease;
        }

        .shop-card:hover {
            border-color: #4cd964;
            transform: translateY(-5px);
        }

        .shop-card h3 {
            font-size: 20px;
            margin-bottom: 10px;
            color: #fff;
        }

        .shop-card .desc {
            color: #999;
            font-size: 14px;
            margin-bottom: 15px;
            line-height: 1.5;
        }

        .price {
            font-size: 22px;
            color: #ffcc00;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .buy-btn {
            width: 100%;
            padding: 10px;
            background: #4cd964;
            border: none;
            border-radius: 8px;
            color: #000;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }

        .buy-btn:hover {
            background: #3bc053;
        }

        .footer {
            text-align: center;
            margin-top: 50px;
            padding: 20px;
            color: #666;
            border-top: 1px solid #333;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>我的世界 服务器商城</h1>
        <p>服务器IP：mc.example.com | 版本：1.20.1 生存服</p>
    </div>

    <div class="container">
        <!-- 商品1 会员 -->
        <div class="shop-card">
            <h3>月卡会员</h3>
            <div class="desc">
                飞行权限、领地多开、每日礼包、专属前缀
            </div>
            <div class="price">¥15.00</div>
            <button class="buy-btn" onclick="buyGoods('月卡会员')">立即购买</button>
        </div>

        <!-- 商品2 点券 -->
        <div class="shop-card">
            <h3>1000服务器点券</h3>
            <div class="desc">
                可兑换物资、神器、皮肤、领地扩容
            </div>
            <div class="price">¥10.00</div>
            <button class="buy-btn" onclick="buyGoods('1000服务器点券')">立即购买</button>
        </div>

        <!-- 商品3 神器 -->
        <div class="shop-card">
            <h3>创世神斧</h3>
            <div class="desc">
                超高伤害、耐久无限、自带锋利V附魔
            </div>
            <div class="price">¥25.00</div>
            <button class="buy-btn" onclick="buyGoods('创世神斧')">立即购买</button>
        </div>

        <!-- 商品4 地皮 -->
        <div class="shop-card">
            <h3>大型领地地皮</h3>
            <div class="desc">
                超大建造范围、禁止他人破坏、自动保护
            </div>
            <div class="price">¥20.00</div>
            <button class="buy-btn" onclick="buyGoods('大型领地地皮')">立即购买</button>
        </div>

        <!-- 商品5 年卡 -->
        <div class="shop-card">
            <h3>年费至尊会员</h3>
            <div class="desc">
                全权限解锁、免费领物资、专属称号、管理员特权
            </div>
            <div class="price">¥128.00</div>
            <button class="buy-btn" onclick="buyGoods('年费至尊会员')">立即购买</button>
        </div>

        <!-- 商品6 礼包 -->
        <div class="shop-card">
            <h3>新手豪华礼包</h3>
            <div class="desc">
                全套钻石装、食物、附魔书、启动物资
            </div>
            <div class="price">¥6.00</div>
            <button class="buy-btn" onclick="buyGoods('新手豪华礼包')">立即购买</button>
        </div>
    </div>

    <div class="footer">
        © 2025 我的世界服务器商店 版权所有 | 联系管理员QQ：123456789
    </div>

    <script>
        // 购买点击弹窗
        function buyGoods(name) {
            alert(`你选择购买：${name}\n请联系管理员QQ进行付款发货！`);
        }
    </script>
</body>
</html>
